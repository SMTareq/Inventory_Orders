@model IEnumerable<InventoryOrderSystem.ViewModels.OrderListViewModel>
@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-cart3 me-2 text-primary"></i>Orders</h2>
    <div class="d-flex gap-2">
        <a asp-action="ExportCsv" class="btn btn-outline-success">
            <i class="bi bi-file-earmark-csv me-1"></i>Export CSV
        </a>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Order
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Items</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">#@o.Id</span></td>
                            <td class="fw-semibold">@o.CustomerName</td>
                            <td>@o.OrderDate.ToString("MMM d, yyyy HH:mm")</td>
                            <td><span class="badge bg-info text-dark">@o.ItemCount item@(o.ItemCount != 1 ? "s" : "")</span></td>
                            <td class="text-end fw-bold text-success">@o.TotalAmount.ToString("C")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-eye me-1"></i>Details
                                </a>
                                <form asp-action="Delete" asp-route-id="@o.Id" method="post" class="d-inline confirm-delete">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger" type="submit">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted py-5">
                            <i class="bi bi-cart-x fs-1 d-block mb-2"></i>No orders yet.
                            <a asp-action="Create" class="btn btn-primary mt-2">Create First Order</a>
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
